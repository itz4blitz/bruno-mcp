{
  "name": "bruno-mcp",
  "version": "1.0.0",
  "description": "MCP server for generating Bruno API testing files",
  "keywords": [
    "api-testing",
    "bru-files",
    "bruno",
    "mcp",
    "model-context-protocol",
    "testing"
  ],
  "homepage": "https://github.com/macarthy/bruno-mcp#readme",
  "bugs": {
    "url": "https://github.com/macarthy/bruno-mcp/issues"
  },
  "license": "MIT",
  "author": "Your Name",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macarthy/bruno-mcp.git"
  },
  "bin": {
    "bruno-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/index.ts",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:acceptance",
    "test:acceptance": "tsx --test tests/acceptance/*.test.ts",
    "test:integration": "tsx --test tests/integration/*.test.ts",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@usebruno/cli": "3.2.2",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.2"
}
