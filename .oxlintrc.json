{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "coverage",
    "dist",
    "docs",
    "generated-collections",
    "node_modules",
    "package-lock.json",
    "test-collections"
  ]
}
